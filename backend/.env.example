NODE_ENV=development
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Single origin or comma-separated list (must include your deployed web origin)
CORS_ORIGIN=http://localhost:3000

# --- Firestore (Firebase Admin) — required for this API ---
# Web NEXT_PUBLIC_FIREBASE_* keys live in frontend/.env* only; they cannot replace this.
#
# Fastest (no path in .env): save the downloaded key JSON in this folder as:
#   firebase-service-account.local.json
# OR place the default-named file from Google (…firebase-adminsdk….json) in this folder.
#
# Option A — entire service account JSON as ONE line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# Option B — absolute path to the key file:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\key.json
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\key.json
#
# Key: Firebase Console → Project settings → Service accounts → Generate new private key
